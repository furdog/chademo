     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro4">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>004</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.4 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>When the protective conductor between the charger and the vehicle is disconnected, the</text:p><text:p>charger shall stop charging within 10 s.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro6">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>005</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.5 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>The charger shall be able to detect loss of isolation, short circuit, and earth faults.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro6">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>006</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.6 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>The charger shall be equipped with an overvoltage protection function.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro7">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>007</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.7 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>The system shall be designed so that a level of voltage that is dangerous to the human body</text:p><text:p>shall not be applied on the charging connector when the connector is not connected to the</text:p><text:p>Vehicle.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro4">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>008</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.8 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>The system shall be designed to prevent users from touching electrically energized parts on</text:p><text:p>the vehicle and the charger.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce45" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Out of Scope </text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce22"/>
     <table:table-cell table:style-name="ce58" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>Not a responsibility of software</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro4">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>009</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.9 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>The charger shall be equipped with a means of earth leakage current detection and automatic</text:p><text:p>Disconnection to help prevent electric shock.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro8">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>010</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.10 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>The charger or charging connector shall be equipped with measures (e.g., plastic cap on</text:p><text:p>connector power terminals) to reduce the risk of contact with exposed live parts as a measure</text:p><text:p>against remaining electric charge on the charging connector.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce45" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Out of Scope </text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce22"/>
     <table:table-cell table:style-name="ce58" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>Not a responsibility of software</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro4">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>011</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.11 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>The charger shall be equipped with a means of protection against overload and short circuit in</text:p><text:p>the ac main circuit or internal circuit of the charger.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro8">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>012</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 a.12 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>The charging system shall be designed so that the voltage level between any accessible</text:p><text:p>conductive parts, including charging cable and charging connector, and any grounding parts</text:p><text:p>decreases to less than 60 V within 1 s or less, after connector removal from station or vehicle.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce29" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce34"/>
     <table:covered-table-cell table:style-name="ce38"/>
     <table:table-cell table:style-name="ce54" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Not complete</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro7">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>013</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 b (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>A data communications interface shall be used to transmit parameters required for charging control.</text:p><text:p>The charger and vehicle shall exchange the parameters through the interface.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce22" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>Communications</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell table:style-name="ce52" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Revision required</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce54"/>
     <table:table-cell table:style-name="ce58" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>Two interfaces responsible for sending and receiving charging control parameters has been implemented</text:p><text:p/><text:p>TODO verify by tests</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce62"/>
     <table:covered-table-cell table:style-name="ce66"/>
     <table:table-cell table:style-name="ce22" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>see implementation of:</text:p><text:p><text:tab/>struct _chademo_se_vcan_tx</text:p><text:p><text:tab/>struct _chademo_se_vcan_rx</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce35"/>
     <table:covered-table-cell table:style-name="ce39"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro9">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>014</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce15" office:value-type="string" calcext:value-type="string">
      <text:p>5.2 c.1 (p. 6)</text:p>
     </table:table-cell>
     <table:table-cell table:style-name="ce18" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>The charger enclosure shall have a rating of IP33 or higher.</text:p>
     </table:table-cell>
     <table:covered-table-cell table:number-columns-repeated="2" table:style-name="ce18"/>
     <table:table-cell table:style-name="ce28" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1"><text:p>Outdoor/indoor conductive charging</text:p><text:p>The charger shall be designed to endure the following environmental conditions</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce33"/>
     <table:covered-table-cell table:style-name="ce37"/>
     <table:table-cell table:style-name="ce45" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="2" table:number-rows-spanned="1">
      <text:p>Out of Scope </text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce22"/>
     <table:table-cell table:style-name="ce59" office:value-type="string" calcext:value-type="string" table:number-columns-spanned="3" table:number-rows-spanned="1">
      <text:p>Not a responsibility of software</text:p>
     </table:table-cell>
     <table:covered-table-cell table:style-name="ce63"/>
     <table:covered-table-cell table:style-name="ce67"/>
     <table:table-cell table:style-name="ce28" table:number-columns-spanned="3" table:number-rows-spanned="1"/>
     <table:covered-table-cell table:style-name="ce33"/>
     <table:covered-table-cell table:style-name="ce37"/>
     <table:table-cell/>
     <table:table-cell table:style-name="ce17" table:number-columns-repeated="16367"/>
    </table:table-row>
    <table:table-row table:style-name="ro10">
     <table:table-cell table:style-name="ce8" office:value-type="string" calcext:value-type="string">
      <text:p>015</text:p>
