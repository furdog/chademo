span class=3D"n">acIn</span><span class=3D"p">[</span><span class=3D"mi">4<=
/span><span class=3D"p">];</span><span class=3D"w"></span>
<span class=3D"kt">unsigned</span><span class=3D"w"> </span><span class=3D"=
n">NumBytes</span><span class=3D"w"> </span><span class=3D"o">=3D</span><sp=
an class=3D"w"> </span><span class=3D"k">sizeof</span><span class=3D"p">(</=
span><span class=3D"n">acIn</span><span class=3D"p">);</span><span class=3D=
"w"></span>
<span class=3D"n">NumBytes</span><span class=3D"w"> </span><span class=3D"o=
">=3D</span><span class=3D"w"> </span><span class=3D"n">SEGGER_RTT_Read</sp=
an><span class=3D"p">(</span><span class=3D"mi">0</span><span class=3D"p">,=
</span><span class=3D"w"> </span><span class=3D"o">&amp;</span><span class=
=3D"n">acIn</span><span class=3D"p">[</span><span class=3D"mi">0</span><spa=
n class=3D"p">],</span><span class=3D"w"> </span><span class=3D"n">NumBytes=
